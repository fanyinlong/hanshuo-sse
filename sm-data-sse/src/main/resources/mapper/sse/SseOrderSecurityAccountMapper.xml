<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shenmei.data.sse.mapper.SseOrderSecurityAccountMapper">

    <resultMap type="SseOrderSecurityAccount" id="SseOrderSecurityAccountResult">
        <result property="pkId"    column="pk_id"    />
        <result property="ruleId"    column="rule_id"    />
        <result property="securityId"    column="security_id"    />
        <result property="accountId"    column="account_id"    />
        <result property="field1"    column="field_1"    />
        <result property="field2"    column="field_2"    />
    </resultMap>

    <sql id="selectSseOrderSecurityAccountVo">
        select pk_id, rule_id, security_id, account_id, field_1, field_2 from sse_order_security_account
    </sql>

    <select id="selectSseOrderSecurityAccountList" parameterType="SseOrderSecurityAccount" resultMap="SseOrderSecurityAccountResult">
        <include refid="selectSseOrderSecurityAccountVo"/>
        <where>
            <if test="ruleId != null "> and rule_id = #{ruleId}</if>
            <if test="securityId != null  and securityId != ''"> and security_id = #{securityId}</if>
            <if test="accountId != null  and accountId != ''"> and account_id = #{accountId}</if>
            <if test="field1 != null  and field1 != ''"> and field_1 = #{field1}</if>
            <if test="field2 != null  and field2 != ''"> and field_2 = #{field2}</if>
        </where>
    </select>

    <select id="selectSseOrderSecurityAccountByPkId" parameterType="Long" resultMap="SseOrderSecurityAccountResult">
        <include refid="selectSseOrderSecurityAccountVo"/>
        where pk_id = #{pkId}
    </select>

    <insert id="insertSseOrderSecurityAccount" parameterType="SseOrderSecurityAccount" useGeneratedKeys="true" keyProperty="pkId">
        insert into sse_order_security_account
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ruleId != null">rule_id,</if>
            <if test="securityId != null">security_id,</if>
            <if test="accountId != null">account_id,</if>
            <if test="field1 != null">field_1,</if>
            <if test="field2 != null">field_2,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="ruleId != null">#{ruleId},</if>
            <if test="securityId != null">#{securityId},</if>
            <if test="accountId != null">#{accountId},</if>
            <if test="field1 != null">#{field1},</if>
            <if test="field2 != null">#{field2},</if>
        </trim>
    </insert>

    <update id="updateSseOrderSecurityAccount" parameterType="SseOrderSecurityAccount">
        update sse_order_security_account
        <trim prefix="SET" suffixOverrides=",">
            <if test="ruleId != null">rule_id = #{ruleId},</if>
            <if test="securityId != null">security_id = #{securityId},</if>
            <if test="accountId != null">account_id = #{accountId},</if>
            <if test="field1 != null">field_1 = #{field1},</if>
            <if test="field2 != null">field_2 = #{field2},</if>
        </trim>
        where pk_id = #{pkId}
    </update>

    <delete id="deleteSseOrderSecurityAccountByPkId" parameterType="Long">
        delete from sse_order_security_account where pk_id = #{pkId}
    </delete>

    <delete id="deleteSseOrderSecurityAccountByPkIds" parameterType="String">
        delete from sse_order_security_account where pk_id in
        <foreach item="pkId" collection="array" open="(" separator="," close=")">
            #{pkId}
        </foreach>
    </delete>

    <insert id="batchInsertSseOrderSecurityAccount" parameterType="java.util.List" useGeneratedKeys="true" keyProperty="pkId">
        INSERT INTO sse_order_security_account (
        rule_id,
        security_id,
        account_id,
        field_1,
        field_2
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
            #{item.ruleId},
            #{item.securityId},
            #{item.accountId},
            #{item.field1},
            #{item.field2}
            )
        </foreach>
    </insert>
</mapper>